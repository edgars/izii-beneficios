        "dataAdesao": { "$ref": "#/definitions/DateTimeLocal" },
        "dataAdmissao": { "$ref": "#/definitions/DateTimeLocal" },
        "dataEvento": { "$ref": "#/definitions/DateTimeLocal" },
        "horaEvento": { "$ref": "#/definitions/TimeHHmm" },
        "endereco": { "$ref": "#/definitions/EnderecoInclusao" },
