        "conta": { "type": "string" },
        "digitoConta": { "type": "string" },
        "tipoConta": { "type": "string" },
        "numero": { "type": "string" },
        "tipoOperacao": { "type": "string" }
      },
      "required": ["banco", "agencia", "conta", "digitoConta", "tipoConta"]
    },
    "DadosBancariosBasico": {
      "type": "object",
